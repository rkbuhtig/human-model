{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rkbuhtig/human-model/research/benchmarks/interp-001b-m1-conformance-report.schema.json",
  "title": "INTERP-001B M1 phase-complete synthetic conformance report",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "report", "integrity"],
  "properties": {
    "$schema": {
      "const": "./interp-001b-m1-conformance-report.schema.json"
    },
    "report": { "$ref": "#/$defs/report" },
    "integrity": { "$ref": "#/$defs/integrity" }
  },
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "failureCode": {
      "enum": [
        "ARTIFACT_BINDING_MISMATCH",
        "ASSERTION_FAILURE",
        "DEAD_PREDICATE_DECLARATION",
        "DUPLICATE_CELL",
        "FIXTURE_RESOLUTION_FAILURE",
        "GUARD_ATTESTATION_FAILURE",
        "IMPLEMENTATION_BINDING_MISMATCH",
        "INPUT_INTEGRITY_FAILURE",
        "MIRROR_TRANSFORM_FAILURE",
        "MISSING_CELL",
        "OPERATOR_LOG_CARDINALITY_FAILURE",
        "REPORT_SCHEMA_FAILURE",
        "RESULT_SCHEMA_FAILURE",
        "RETIREMENT_EVALUATION_FAILURE",
        "RUN_MATRIX_MISMATCH",
        "SIGNATURE_RELATION_FAILURE",
        "SIGNATURE_RESOLUTION_FAILURE",
        "UNKNOWN_PREDICATE"
      ]
    },
    "failureCodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/failureCode" },
      "uniqueItems": true
    },
    "artifactBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_manifest_file_sha256",
        "execution_manifest_sha256",
        "execution_contract_sha256",
        "evaluation_manifest_file_sha256",
        "evaluation_manifest_sha256",
        "evaluation_contract_sha256",
        "cell_result_schema_sha256",
        "run_artifact_schema_sha256",
        "evaluator_policy_sha256",
        "report_schema_sha256",
        "run_sha256"
      ],
      "properties": {
        "execution_manifest_file_sha256": { "$ref": "#/$defs/sha256" },
        "execution_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "execution_contract_sha256": { "$ref": "#/$defs/sha256" },
        "evaluation_manifest_file_sha256": { "$ref": "#/$defs/sha256" },
        "evaluation_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "evaluation_contract_sha256": { "$ref": "#/$defs/sha256" },
        "cell_result_schema_sha256": { "$ref": "#/$defs/sha256" },
        "run_artifact_schema_sha256": { "$ref": "#/$defs/sha256" },
        "evaluator_policy_sha256": { "$ref": "#/$defs/sha256" },
        "report_schema_sha256": { "$ref": "#/$defs/sha256" },
        "run_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "implementationBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_id", "implementation_version", "module_path", "source_sha256", "bundle_sha256"],
      "properties": {
        "implementation_id": { "$ref": "#/$defs/token" },
        "implementation_version": { "const": "1.0.0" },
        "module_path": { "$ref": "#/$defs/token" },
        "source_sha256": { "$ref": "#/$defs/sha256" },
        "bundle_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "implementationBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "evaluator"],
      "properties": {
        "runner": { "$ref": "#/$defs/implementationBinding" },
        "evaluator": { "$ref": "#/$defs/implementationBinding" }
      }
    },
    "inputSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared_fixture_count",
        "declared_model_count",
        "expected_cell_count",
        "reported_cell_count",
        "reported_step_count"
      ],
      "properties": {
        "declared_fixture_count": { "type": "integer", "minimum": 0 },
        "declared_model_count": { "type": "integer", "minimum": 0 },
        "expected_cell_count": { "type": "integer", "minimum": 0 },
        "reported_cell_count": { "type": "integer", "minimum": 0 },
        "reported_step_count": { "type": "integer", "minimum": 0 }
      }
    },
    "schemaValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "validated_cell_count", "failure_codes"],
      "properties": {
        "status": { "enum": ["PASS", "FAIL"] },
        "validated_cell_count": { "type": "integer", "minimum": 0 },
        "failure_codes": { "$ref": "#/$defs/failureCodes" }
      }
    },
    "signatureResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_key",
        "model_id",
        "protocol_step",
        "signature_id",
        "status",
        "evaluated_relation_count",
        "failed_relation_paths",
        "failure_codes"
      ],
      "properties": {
        "fixture_key": { "$ref": "#/$defs/token" },
        "model_id": { "enum": ["R0", "R1", "R2", "R3"] },
        "protocol_step": { "type": "integer", "minimum": 1 },
        "signature_id": { "$ref": "#/$defs/token" },
        "status": { "enum": ["PASS", "FAIL"] },
        "evaluated_relation_count": { "type": "integer", "minimum": 0 },
        "failed_relation_paths": {
          "type": "array",
          "items": { "type": "string", "pattern": "^/semantic/" },
          "uniqueItems": true
        },
        "failure_codes": { "$ref": "#/$defs/failureCodes" }
      }
    },
    "assertionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertion_id",
        "predicate_id",
        "assertion_group",
        "status",
        "failure_codes"
      ],
      "properties": {
        "assertion_id": { "$ref": "#/$defs/token" },
        "predicate_id": { "$ref": "#/$defs/token" },
        "assertion_group": {
          "enum": ["mirror", "cell", "pair", "matrix", "global"]
        },
        "status": { "enum": ["PASS", "FAIL"] },
        "failure_codes": { "$ref": "#/$defs/failureCodes" }
      }
    },
    "retirementResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertion_id",
        "predicate_id",
        "status",
        "decision",
        "targets",
        "reason_code",
        "failure_codes"
      ],
      "properties": {
        "assertion_id": { "$ref": "#/$defs/token" },
        "predicate_id": { "$ref": "#/$defs/token" },
        "status": { "enum": ["TRIGGERED", "NOT_TRIGGERED", "NOT_EVALUABLE"] },
        "decision": {
          "enum": [
            "REMOVE_OPERATOR",
            "REJECT_MODEL",
            "REMOVE_CONTRIBUTION",
            "RETIRE_EXTRA_DEGREES",
            "RETAIN"
          ]
        },
        "targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/token" },
          "uniqueItems": true
        },
        "reason_code": {
          "enum": [
            "CONDITION_FALSE",
            "CONDITION_TRUE",
            "MISSING_SINGLE_THRESHOLD_BASELINE"
          ]
        },
        "failure_codes": { "$ref": "#/$defs/failureCodes" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature_pass_count",
        "signature_fail_count",
        "assertion_pass_count",
        "assertion_fail_count",
        "retirement_triggered_count",
        "retirement_not_triggered_count",
        "retirement_not_evaluable_count"
      ],
      "properties": {
        "signature_pass_count": { "type": "integer", "minimum": 0 },
        "signature_fail_count": { "type": "integer", "minimum": 0 },
        "assertion_pass_count": { "type": "integer", "minimum": 0 },
        "assertion_fail_count": { "type": "integer", "minimum": 0 },
        "retirement_triggered_count": { "type": "integer", "minimum": 0 },
        "retirement_not_triggered_count": { "type": "integer", "minimum": 0 },
        "retirement_not_evaluable_count": { "type": "integer", "minimum": 0 }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluation_domain",
        "prefix_claim_kind",
        "independent_cryptographic_prefix_proof",
        "runtime_ledgers_observed",
        "human_empirical_evidence"
      ],
      "properties": {
        "evaluation_domain": { "const": "detached_synthetic_structural_conformance" },
        "prefix_claim_kind": { "const": "runner_implementation_bound_attestation_audit" },
        "independent_cryptographic_prefix_proof": { "const": false },
        "runtime_ledgers_observed": { "const": false },
        "human_empirical_evidence": { "const": false }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "report_version",
        "policy_id",
        "policy_version",
        "status",
        "artifact_bindings",
        "implementation_bindings",
        "input_summary",
        "schema_validation",
        "signature_results",
        "assertion_results",
        "retirement_results",
        "summary",
        "failure_codes",
        "observability",
        "disclaimers"
      ],
      "properties": {
        "report_id": { "const": "INTERP-001B-M1-CONFORMANCE-REPORT" },
        "report_version": { "const": "1.0.0" },
        "policy_id": { "const": "INTERP-001B-M1-EVALUATOR-POLICY" },
        "policy_version": { "const": "1.0.0" },
        "status": { "enum": ["PASS", "FAIL"] },
        "artifact_bindings": { "$ref": "#/$defs/artifactBindings" },
        "implementation_bindings": { "$ref": "#/$defs/implementationBindings" },
        "input_summary": { "$ref": "#/$defs/inputSummary" },
        "schema_validation": { "$ref": "#/$defs/schemaValidation" },
        "signature_results": {
          "type": "array",
          "minItems": 88,
          "maxItems": 88,
          "items": { "$ref": "#/$defs/signatureResult" },
          "uniqueItems": true
        },
        "assertion_results": {
          "type": "array",
          "minItems": 54,
          "maxItems": 54,
          "items": { "$ref": "#/$defs/assertionResult" },
          "uniqueItems": true
        },
        "retirement_results": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/retirementResult" },
          "uniqueItems": true
        },
        "summary": { "$ref": "#/$defs/summary" },
        "failure_codes": { "$ref": "#/$defs/failureCodes" },
        "observability": { "$ref": "#/$defs/observability" },
        "disclaimers": {
          "const": [
            "ReceptionStateSnapshot is a synthetic declared reception condition, not measured human mood.",
            "SubjectiveEncounterFormProxy is a detached model output, not qualia or a first-person report.",
            "Guard and prefix checks are evaluator recomputations bound to this runner implementation, not independent cryptographic proof or runtime-ledger observation.",
            "Synthetic structural conformance is not a human law, predictive support, recovery measurement, target-form measurement, Ghost-process measurement, or mental-time measurement."
          ]
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "canonicalization_id", "report_sha256"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "canonicalization_id": { "const": "interp-canonical-json-v1" },
        "report_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}

        "causal_attribution",
        "control_attribution",
        "reflective_ownership",
        "endorsement",
        "responsibility_acceptance"
      ],
      "updates": "COMPATIBLE_TYPED_RECEIPTS_ONLY"
    },
    "slow": {
      "fields": [
        "trust_expectation",
        "continuation_commitment",
        "counterpart_reliability",
        "expected_repair"
      ],
      "updates": "CONSOLIDATION_EVENTS_ONLY"
    }

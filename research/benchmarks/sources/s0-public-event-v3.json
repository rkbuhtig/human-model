{
  "schema_version": "s0-public-event-v3-contract/1.0.0",
  "union": {
    "OccurrenceEvent": ["ordinal", "occurrence_kind", "scope", "actor", "target"],
    "ActionEvent": ["ordinal", "action_category", "actor", "target"],
    "FeedbackEvent": ["ordinal", "feedback_category", "actor", "target"],
    "ContextEvent": ["ordinal", "context_kind", "actor", "target"],
    "NoEvent": ["ordinal", "canonical_tick_count"]
  },
  "discriminant": "event_type",
  "generic_public_value_field": "FORBIDDEN",
  "ordinal_rule": "EXACT_CONTINUOUS_1_TO_N",
  "no_event_rule": "ONE_NO_EVENT_EQUALS_ONE_CANONICAL_PROCESS_TICK",
  "observable_prefix_fields": ["schema_version", "context", "events"],
  "join_metadata_excluded_from_observable_digest": [
    "source_instance_id",
    "trajectory_id",
    "prediction_point_id",
    "evaluator_continuation_condition"
  ],
  "continuation_condition_model_visible": false
}

{
  "schema_version": "s0-source-family-public/1.0.0",
  "family_id": "SIM-REL-BOUNDARY-FAMILY-001",
  "supersedes_single_source_id": "SIM-REL-BOUNDARY-001",
  "source_class": "NON_HUMAN_SYNTHETIC_HIDDEN_PROCESS_FAMILY",
  "human_empirical_support": "NONE",
  "episode_family": "RELATIONSHIP_BOUNDARY_SINGLE_FAMILY",
  "instance_count": 16,
  "generator": {
    "module": "dynamics.s0.source_family",
    "version": "sim-rel-boundary-family-generator/1.0.0",
    "hyperprior": "sim-rel-boundary-family-001-hyperprior.json",
    "model_modules_may_be_imported": false,
    "model_outputs_or_scores_may_be_read": false
  },
  "latent_state_contract": {
    "count": 6,
    "public_names": ["q0", "q1", "q2", "q3", "q4", "q5"],
    "semantic_names_visible_to_models": false,
    "must_not_use_h_model_field_names": true
  },
  "conditions": {
    "history": ["H-STABLE", "H-BREACH"],
    "continuation": ["F-REPAIR", "F-DEFLECT", "F-REPEAT", "F-PUBLIC"]
  },
  "seed_resolution": {
    "beacon": "DRAND_QUICKNET",
    "round_selection_rule": "FIRST_VERIFIABLE_ROUND_WITH_TIMESTAMP_AT_OR_AFTER_MERGE_COMMIT_TIMESTAMP_PLUS_3600_SECONDS",
    "family_seed_formula": "SHA256(generator_version|family_id|merge_commit_sha|generator_blob_sha|hyperprior_blob_sha|beacon_randomness)",
    "instance_seed_formula": "SHA256(family_seed|instance_index|accepted_candidate_attempt)",
    "beacon_evidence_required": [
      "chain_hash",
      "round",
      "round_timestamp",
      "randomness",
      "signature",
      "verification_result"
    ]
  },
  "instance_policy": {
    "all_generated_instances_included": true,
    "model_based_acceptance_or_rejection": false,
    "manual_matrix_tuning_after_seed_resolution": false,
    "instance_replacement_after_generation": false
  },
  "dataset_allocation": {
    "development_total": 256,
    "evaluation_total": 1024,
    "stability_total": 1024,
    "per_instance_development": 16,
    "per_instance_evaluation": 64,
    "per_instance_stability": 64,
    "condition_balance": "equal across 2 history by 4 continuation cells within every instance and split"
  },
  "evaluation": {
    "primary_claim_unit": "SOURCE_FAMILY",
    "per_instance_scores_required": true,
    "pooled_scores_required": true,
    "bootstrap": "HIERARCHICAL_INSTANCE_THEN_TRAJECTORY",
    "instance_direction_consistency_required": true
  },
  "authority_note": "The public generator and multiple future-seeded instances reduce source-tailoring risk but do not prove complete model independence. Results remain non-human source-family-conditional adequacy."
}

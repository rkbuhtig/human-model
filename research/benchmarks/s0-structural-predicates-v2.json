      "matched_dimension": "history_condition",
      "left": "H-STABLE",
      "right": "H-BREACH",
      "formula": "threat_mass(right) - threat_mass(left) >= 0",
      "threat_categories": ["ASSERT_BOUNDARY", "TEMPORARY_WITHDRAWAL", "PUNITIVE_ATTACK", "RELATION_EXIT"],
      "exceptions": []
    },
    {
      "predicate_id": "A-C2-REPAIR-DISCRIMINATION-V2",
      "matched_dimension": "continuation_condition",
      "left": "F-REPAIR",
      "right": "F-DEFLECT",
      "formula": "healthy_region_mass(left) - healthy_region_mass(right) > 0",
      "healthy_regions": ["PARTIAL_REPAIR", "GUARDED_CONTINUATION"]
    },
    {
      "predicate_id": "A-C3-REPETITION-SENSITIVITY-V2",
      "matched_dimension": "context_variant",
      "left": "MATCHED_NO_REPEAT",
      "right": "MATCHED_REPEAT",
      "formula": "P(PARTIAL_REPAIR|left) - P(PARTIAL_REPAIR|right) >= 0"
    },
    {
      "predicate_id": "A-C4-PROJECTION-SELECTIVITY-V2",
      "matched_dimension": "context_variant",
      "left": "PRIVATE_MATCH",
      "right": "PUBLIC_MATCH",
      "formula": "P(SUPPRESS_FOR_ROLE|right) - P(SUPPRESS_FOR_ROLE|left) >= 0"
    },
    {
      "predicate_id": "A-C5-LOCAL-VARIATION-V2",
      "formula": "not universal_mode_collapse and maximum_pairwise_total_variation >= 0.05",
      "universal_single_category_max_probability": 0.98,
      "minimum_intervention_total_variation": 0.05
    }
  ],
  "non_predicates": [

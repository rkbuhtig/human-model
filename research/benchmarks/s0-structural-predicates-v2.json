      "former_id": "A-C6-NO-AUTOMATIC-HEALTHY-CONVERGENCE",
      "status": "INTERPRETIVE_NON_REQUIREMENT_NOT_PASS_FAIL"
    },
    {
      "former_id": "A-C7-AUTHORITY-INTEGRITY",
      "status": "MOVED_TO_IMPLEMENTATION_INTEGRITY_TESTS",
      "required_tests": [
        "INPUT_RECEIPT_BYTES_IMMUTABLE",
        "RECEIPT_SCOPE_NOT_PROMOTED",
        "ACTION_OCCURRENCE_NOT_AUTO_ENDORSEMENT_OR_RESPONSIBILITY",
        "NORMATIVE_AUTHORITY_STATE_NOT_UPDATED_WITHOUT_TYPED_COMPATIBLE_RECEIPT"
      ]
    }
  ],
  "implementation_module": "dynamics.s0.structural"

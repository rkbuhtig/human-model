{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "P0-v1 exact rendered delivery surface catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "artifact_type",
    "artifact_id",
    "deliveries",
    "status",
    "authority",
    "participant_surface_binding",
    "renderer_semantics_version",
    "encoding"
  ],
  "properties": {
    "$schema": {
      "const": "./rendered-surface-catalog-v1.schema.json"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "artifact_type": {
      "const": "RENDERED_PARTICIPANT_SURFACE_CATALOG"
    },
    "artifact_id": {
      "const": "INTERP-DIALOGUE-001P0-V1-RENDERED-SURFACES"
    },
    "deliveries": {
      "type": "array",
      "minItems": 37,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "delivery_surface_id",
          "delivery_kind",
          "family_id",
          "source_surface_refs",
          "participant_text",
          "utf8_base64",
          "utf8_byte_length",
          "utf8_sha256"
        ],
        "properties": {
          "delivery_surface_id": {
            "$ref": "#/$defs/token"
          },
          "delivery_kind": {
            "enum": [
              "INITIAL_PRESENTATION",
              "FUTURE_OPTION",
              "IMMEDIATE_PROMPT",
              "LATER_PROMPT",
              "POST_TRACE_DIAGNOSTIC_PROMPT"
            ]
          },
          "family_id": {
            "$ref": "#/$defs/token"
          },
          "source_surface_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/token"
            }
          },
          "participant_text": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "utf8_base64": {
            "type": "string"
          },
          "utf8_byte_length": {
            "type": "integer",
            "minimum": 1
          },
          "utf8_sha256": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "status": {
      "const": "FROZEN_DERIVED_UNEXECUTED"
    },
    "authority": {
      "const": "EXACT_DELIVERY_BYTES_ONLY_NO_OCCURRENCE_AUTHORITY"
    },
    "participant_surface_binding": {
      "$ref": "#/$defs/binding"
    },
    "renderer_semantics_version": {
      "const": "INTERP-DIALOGUE-P0-V1-RENDERER-1.0.0"
    },
    "encoding": {
      "const": "BASE64_OF_EXACT_UTF8_BYTES"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "token": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "path",
        "content_sha256"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rkbuhtig/human-model/research/scenarios/interp-dialogue-001/elicitation/session-input.schema.json",
  "title": "INTERP-DIALOGUE-001P0 scripted elicitation replay input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "artifact_type",
    "run_id",
    "instrument_binding",
    "source_kind",
    "sessions"
  ],
  "properties": {
    "$schema": {"const": "./session-input.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "DEVELOPMENT_ELICITATION_SCRIPT_INPUT"},
    "run_id": {"$ref": "#/$defs/token"},
    "instrument_binding": {"$ref": "#/$defs/instrumentBinding"},
    "source_kind": {
      "enum": [
        "SCRIPTED_ADVERSARIAL_RESPONSE"
      ]
    },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/session"}
    }
  },
  "$defs": {
    "token": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "base64": {"type": "string", "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"},
    "instrumentBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument_id", "instrument_version", "content_sha256"],
      "properties": {
        "instrument_id": {"const": "INTERP-DIALOGUE-001P0-ELICITATION-INSTRUMENT-V0"},
        "instrument_version": {"const": "0.0.0"},
        "content_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "presentPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "encoding", "raw_payload_utf8_base64", "byte_length", "content_sha256", "normalization"],
      "properties": {
        "status": {"const": "PRESENT"},
        "encoding": {"const": "BASE64_OF_EXACT_UTF8_BYTES"},
        "raw_payload_utf8_base64": {"$ref": "#/$defs/base64"},
        "byte_length": {"type": "integer", "minimum": 0},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "normalization": {"const": "NONE"}
      }
    },
    "absentPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"const": "ABSENT"},
        "reason": {"enum": ["REFUSED", "NO_RESPONSE", "TECHNICAL_FAILURE"]}
      }
    },
    "payloadRecord": {
      "oneOf": [
        {"$ref": "#/$defs/presentPayload"},
        {"$ref": "#/$defs/absentPayload"}
      ]
    },
    "responseSubmission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["response_status", "raw_payload_record"],
      "properties": {
        "response_status": {"enum": ["RESPONDED", "REFUSED", "NO_RESPONSE", "TECHNICAL_FAILURE"]},
        "raw_payload_record": {"$ref": "#/$defs/payloadRecord"}
      }
    },
    "diagnosticOmitted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {"mode": {"const": "OMITTED"}}
    },
    "diagnosticCollected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "response"],
      "properties": {
        "mode": {"const": "COLLECTED_AFTER_R2"},
        "response": {"$ref": "#/$defs/responseSubmission"}
      }
    },
    "diagnostic": {
      "oneOf": [
        {"$ref": "#/$defs/diagnosticOmitted"},
        {"$ref": "#/$defs/diagnosticCollected"}
      ]
    },
    "comparisonAbsent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {"status": {"const": "NOT_APPLICABLE"}}
    },
    "comparisonPresent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "comparison_group_id", "comparison_id", "arm"],
      "properties": {
        "status": {"const": "PRESENT"},
        "comparison_group_id": {"$ref": "#/$defs/token"},
        "comparison_id": {"$ref": "#/$defs/token"},
        "arm": {"enum": ["LEFT", "RIGHT"]}
      }
    },
    "comparisonBinding": {
      "oneOf": [
        {"$ref": "#/$defs/comparisonAbsent"},
        {"$ref": "#/$defs/comparisonPresent"}
      ]
    },
    "responses": {
      "type": "object",
      "additionalProperties": false,
      "required": ["immediate", "later", "post_trace_diagnostic"],
      "properties": {
        "immediate": {"$ref": "#/$defs/responseSubmission"},
        "later": {"$ref": "#/$defs/responseSubmission"},
        "post_trace_diagnostic": {"$ref": "#/$defs/diagnostic"}
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "presentation_id", "future_option_id", "comparison_binding", "responses"],
      "properties": {
        "session_id": {"$ref": "#/$defs/token"},
        "presentation_id": {"$ref": "#/$defs/token"},
        "future_option_id": {"$ref": "#/$defs/token"},
        "comparison_binding": {"$ref": "#/$defs/comparisonBinding"},
        "responses": {"$ref": "#/$defs/responses"}
      }
    }
  }
}

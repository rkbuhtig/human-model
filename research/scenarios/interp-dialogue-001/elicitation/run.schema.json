{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rkbuhtig/human-model/research/scenarios/interp-dialogue-001/elicitation/run.schema.json",
  "title": "INTERP-DIALOGUE-001P0 immutable scripted elicitation replay",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "artifact_type",
    "run_id",
    "status",
    "authority",
    "instrument_binding",
    "session_input_sha256",
    "source_kind",
    "sessions"
  ],
  "properties": {
    "$schema": {"const": "./run.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "DEVELOPMENT_ELICITATION_SCRIPTED_REPLAY"},
    "run_id": {"$ref": "#/$defs/token"},
    "status": {"const": "IMMUTABLE_SCRIPTED_REPLAY_NO_ACTUAL_OCCURRENCE_OR_MECHANISM_RESULT"},
    "authority": {"$ref": "#/$defs/authority"},
    "instrument_binding": {"$ref": "#/$defs/instrumentBinding"},
    "session_input_sha256": {"$ref": "#/$defs/sha256"},
    "source_kind": {"const": "SCRIPTED_ADVERSARIAL_RESPONSE"},
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/session"}
    }
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "token": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "base64": {"type": "string", "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"},
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_role", "response_authority", "mapping_status", "defect_status", "empirical_status"],
      "properties": {
        "artifact_role": {"const": "DEVELOPMENT_ELICITATION_SCRIPTED_REPLAY_ARTIFACT"},
        "response_authority": {"const": "SCRIPTED_RESPONSE_RECORD_AND_PAYLOAD_PROVENANCE_ONLY"},
        "mapping_status": {"const": "NO_MAPPING_EMITTED"},
        "defect_status": {"const": "NO_DEFECT_CLASSIFICATION_EMITTED"},
        "empirical_status": {"const": "NO_ACTUAL_PARTICIPANT_OCCURRENCE_OR_HUMAN_MECHANISM_SUPPORT"}
      }
    },
    "instrumentBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument_id", "instrument_version", "content_sha256"],
      "properties": {
        "instrument_id": {"const": "INTERP-DIALOGUE-001P0-ELICITATION-INSTRUMENT-V0"},
        "instrument_version": {"const": "0.0.0"},
        "content_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "presentPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "encoding", "raw_payload_utf8_base64", "byte_length", "content_sha256", "normalization"],
      "properties": {
        "status": {"const": "PRESENT"},
        "encoding": {"const": "BASE64_OF_EXACT_UTF8_BYTES"},
        "raw_payload_utf8_base64": {"$ref": "#/$defs/base64"},
        "byte_length": {"type": "integer", "minimum": 0},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "normalization": {"const": "NONE"}
      }
    },
    "absentPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"const": "ABSENT"},
        "reason": {"enum": ["REFUSED", "NO_RESPONSE", "TECHNICAL_FAILURE"]}
      }
    },
    "payloadRecord": {
      "oneOf": [
        {"$ref": "#/$defs/presentPayload"},
        {"$ref": "#/$defs/absentPayload"}
      ]
    },
    "deliveryEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "elicitation_step_id", "sequence_ordinal", "event_kind", "payload_record", "authority"],
      "properties": {
        "event_id": {"$ref": "#/$defs/token"},
        "elicitation_step_id": {"$ref": "#/$defs/token"},
        "sequence_ordinal": {"type": "integer", "minimum": 0, "maximum": 7},
        "event_kind": {"enum": ["STIMULUS_DELIVERY", "PROMPT_DELIVERY"]},
        "payload_record": {"$ref": "#/$defs/presentPayload"},
        "authority": {"const": "SCRIPTED_DELIVERY_RECORD_NOT_ACTUAL_OCCURRENCE_OR_ORDINAL_OBSERVATION"}
      }
    },
    "responseEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "elicitation_step_id", "sequence_ordinal", "event_kind", "prompt_delivery_event_id", "response_status", "payload_record", "authority"],
      "properties": {
        "event_id": {"$ref": "#/$defs/token"},
        "elicitation_step_id": {"$ref": "#/$defs/token"},
        "sequence_ordinal": {"type": "integer", "minimum": 0, "maximum": 7},
        "event_kind": {"const": "SCRIPTED_RESPONSE_RECORD"},
        "prompt_delivery_event_id": {"$ref": "#/$defs/token"},
        "response_status": {"enum": ["RESPONDED", "REFUSED", "NO_RESPONSE", "TECHNICAL_FAILURE"]},
        "payload_record": {"$ref": "#/$defs/payloadRecord"},
        "authority": {"const": "SCRIPTED_RESPONSE_RECORD_AND_PAYLOAD_PROVENANCE_ONLY"}
      }
    },
    "event": {
      "oneOf": [
        {"$ref": "#/$defs/deliveryEvent"},
        {"$ref": "#/$defs/responseEvent"}
      ]
    },
    "provenanceLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["link_id", "response_event_id", "prompt_delivery_event_id", "context_delivery_event_ids", "delivered_prompt_sha256", "context_payload_sha256", "authority"],
      "properties": {
        "link_id": {"$ref": "#/$defs/token"},
        "response_event_id": {"$ref": "#/$defs/token"},
        "prompt_delivery_event_id": {"$ref": "#/$defs/token"},
        "context_delivery_event_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/token"}
        },
        "delivered_prompt_sha256": {"$ref": "#/$defs/sha256"},
        "context_payload_sha256": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/sha256"}
        },
        "authority": {"const": "LINKS_SCRIPTED_RESPONSE_RECORD_TO_SCRIPTED_DELIVERY_CONTEXT_ONLY"}
      }
    },
    "comparisonAbsent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {"status": {"const": "NOT_APPLICABLE"}}
    },
    "comparisonPresent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "comparison_group_id", "comparison_id", "arm"],
      "properties": {
        "status": {"const": "PRESENT"},
        "comparison_group_id": {"$ref": "#/$defs/token"},
        "comparison_id": {"$ref": "#/$defs/token"},
        "arm": {"enum": ["LEFT", "RIGHT"]}
      }
    },
    "comparisonBinding": {
      "oneOf": [
        {"$ref": "#/$defs/comparisonAbsent"},
        {"$ref": "#/$defs/comparisonPresent"}
      ]
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "presentation_id", "source_cell_id", "future_option_id", "comparison_binding", "event_log", "response_provenance_links"],
      "properties": {
        "session_id": {"$ref": "#/$defs/token"},
        "presentation_id": {"$ref": "#/$defs/token"},
        "source_cell_id": {"$ref": "#/$defs/token"},
        "future_option_id": {"$ref": "#/$defs/token"},
        "comparison_binding": {"$ref": "#/$defs/comparisonBinding"},
        "event_log": {
          "type": "array",
          "minItems": 6,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/event"}
        },
        "response_provenance_links": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/provenanceLink"}
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rkbuhtig/human-model/research/scenarios/interp-dialogue-001/elicitation/p1/response-corpus.schema.json",
  "title": "INTERP-DIALOGUE-001P1-v0 scripted adversarial response corpus",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "artifact_type",
    "corpus_id",
    "status",
    "authority",
    "scripts"
  ],
  "properties": {
    "$schema": {"const": "./response-corpus.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "P1_SCRIPTED_ADVERSARIAL_RESPONSE_CORPUS"},
    "corpus_id": {"$ref": "#/$defs/token"},
    "status": {"const": "SCRIPTED_ADVERSARIAL_INPUT_ONLY"},
    "authority": {
      "const": "ATTACKS_RECORDING_SCHEMA_AND_AUTHORITY_BOUNDARIES_NOT_SYNTHETIC_HUMAN_EVIDENCE"
    },
    "scripts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/script"}
    }
  },
  "$defs": {
    "token": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "nonEmptyString": {"type": "string", "minLength": 1},
    "slotList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["IMMEDIATE", "LATER", "D0"]}
    },
    "mappingJudgment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_status", "analyst_basis"],
      "properties": {
        "candidate_status": {
          "enum": [
            "PROPOSED_SURFACE_MAPPING",
            "AMBIGUOUS_SURFACE_MAPPING",
            "NO_SURFACE_MAPPING_PROPOSED",
            "OUTSIDE_CURRENT_MAPPING_VOCABULARY_CANDIDATE"
          ]
        },
        "analyst_basis": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "respondedScript": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_id",
        "adversarial_intent",
        "allowed_slots",
        "response_status",
        "payload_utf8",
        "payload_byte_length",
        "payload_sha256"
      ],
      "properties": {
        "script_id": {"$ref": "#/$defs/token"},
        "adversarial_intent": {"$ref": "#/$defs/nonEmptyString"},
        "allowed_slots": {"$ref": "#/$defs/slotList"},
        "response_status": {"const": "RESPONDED"},
        "payload_utf8": {"type": "string"},
        "payload_byte_length": {"type": "integer", "minimum": 0},
        "payload_sha256": {"$ref": "#/$defs/sha256"},
        "mapping_judgment": {"$ref": "#/$defs/mappingJudgment"}
      }
    },
    "absentScript": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_id",
        "adversarial_intent",
        "allowed_slots",
        "response_status"
      ],
      "properties": {
        "script_id": {"$ref": "#/$defs/token"},
        "adversarial_intent": {"$ref": "#/$defs/nonEmptyString"},
        "allowed_slots": {"$ref": "#/$defs/slotList"},
        "response_status": {"enum": ["REFUSED", "NO_RESPONSE", "TECHNICAL_FAILURE"]}
      }
    },
    "script": {
      "oneOf": [
        {"$ref": "#/$defs/respondedScript"},
        {"$ref": "#/$defs/absentScript"}
      ]
    }
  }
}
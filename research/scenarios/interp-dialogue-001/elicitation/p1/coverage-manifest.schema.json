{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rkbuhtig/human-model/research/scenarios/interp-dialogue-001/elicitation/p1/coverage-manifest.schema.json",
  "title": "INTERP-DIALOGUE-001P1-v0 development pilot coverage manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "artifact_type",
    "manifest_id",
    "status",
    "authority",
    "source_kind",
    "minimum_session_count",
    "frozen_input_digests",
    "response_corpus_binding",
    "runs"
  ],
  "properties": {
    "$schema": {"const": "./coverage-manifest.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "P1_DEVELOPMENT_PILOT_COVERAGE_MANIFEST"},
    "manifest_id": {"$ref": "#/$defs/token"},
    "status": {"const": "FROZEN_BEFORE_MATERIALIZATION"},
    "authority": {
      "const": "SCRIPTED_DEVELOPMENT_COVERAGE_DECLARATION_ONLY_NOT_ACQUISITION_OR_MEASUREMENT"
    },
    "source_kind": {"const": "SCRIPTED_ADVERSARIAL_RESPONSE"},
    "minimum_session_count": {"const": 30},
    "frozen_input_digests": {"$ref": "#/$defs/frozenInputDigests"},
    "response_corpus_binding": {"$ref": "#/$defs/corpusBinding"},
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/run"}
    }
  },
  "$defs": {
    "token": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "frozenInputDigests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instrument_sha256",
        "instrument_schema_sha256",
        "session_input_schema_sha256",
        "run_schema_sha256",
        "development_assessment_schema_sha256",
        "scenario_family_sha256",
        "trace_oracle_v1_sha256",
        "trace_oracle_doc_sha256"
      ],
      "properties": {
        "instrument_sha256": {"$ref": "#/$defs/sha256"},
        "instrument_schema_sha256": {"$ref": "#/$defs/sha256"},
        "session_input_schema_sha256": {"$ref": "#/$defs/sha256"},
        "run_schema_sha256": {"$ref": "#/$defs/sha256"},
        "development_assessment_schema_sha256": {"$ref": "#/$defs/sha256"},
        "scenario_family_sha256": {
          "type": "object",
          "additionalProperties": false,
          "required": ["REL-BOUNDARY-001", "WORK-FEEDBACK-001", "RISK-FOOTSTEPS-001"],
          "properties": {
            "REL-BOUNDARY-001": {"$ref": "#/$defs/sha256"},
            "WORK-FEEDBACK-001": {"$ref": "#/$defs/sha256"},
            "RISK-FOOTSTEPS-001": {"$ref": "#/$defs/sha256"}
          }
        },
        "trace_oracle_v1_sha256": {"$ref": "#/$defs/sha256"},
        "trace_oracle_doc_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "corpusBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus_id", "content_sha256"],
      "properties": {
        "corpus_id": {"$ref": "#/$defs/token"},
        "content_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "comparisonAbsent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {"status": {"const": "NOT_APPLICABLE"}}
    },
    "comparisonPresent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "comparison_group_id", "comparison_id", "arm"],
      "properties": {
        "status": {"const": "PRESENT"},
        "comparison_group_id": {"$ref": "#/$defs/token"},
        "comparison_id": {"$ref": "#/$defs/token"},
        "arm": {"enum": ["LEFT", "RIGHT"]}
      }
    },
    "comparisonBinding": {
      "oneOf": [
        {"$ref": "#/$defs/comparisonAbsent"},
        {"$ref": "#/$defs/comparisonPresent"}
      ]
    },
    "diagnosticOmitted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {"mode": {"const": "OMITTED"}}
    },
    "diagnosticCollected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "script_id"],
      "properties": {
        "mode": {"const": "COLLECTED_AFTER_R2"},
        "script_id": {"$ref": "#/$defs/token"}
      }
    },
    "diagnostic": {
      "oneOf": [
        {"$ref": "#/$defs/diagnosticOmitted"},
        {"$ref": "#/$defs/diagnosticCollected"}
      ]
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "presentation_id",
        "source_cell_id",
        "future_option_id",
        "comparison_binding",
        "immediate_script_id",
        "later_script_id",
        "post_trace_diagnostic",
        "session_binding_sha256"
      ],
      "properties": {
        "session_id": {"$ref": "#/$defs/token"},
        "presentation_id": {"$ref": "#/$defs/token"},
        "source_cell_id": {"$ref": "#/$defs/token"},
        "future_option_id": {"$ref": "#/$defs/token"},
        "comparison_binding": {"$ref": "#/$defs/comparisonBinding"},
        "immediate_script_id": {"$ref": "#/$defs/token"},
        "later_script_id": {"$ref": "#/$defs/token"},
        "post_trace_diagnostic": {"$ref": "#/$defs/diagnostic"},
        "session_binding_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "sessions"],
      "properties": {
        "run_id": {"$ref": "#/$defs/token"},
        "sessions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/session"}
        }
      }
    }
  }
}

{
  "$schema": "./contract.schema.json",
  "document_kind": "runtime_spine",
  "schema_version": "1.0.0",
  "contract_id": "INTERP-001D2A0-V0",
  "status": "FROZEN_UNEXECUTED",
  "scope": {
    "name": "MINIMAL_RECURSIVE_INTERPRETATION_SPINE",
    "included": [
      "current_access",
      "declared_runtime_view",
      "immediate_surface_projection",
      "interpretation_candidates",
      "reception",
      "scoped_adjudication",
      "subjective_encounter_form",
      "future_revision_eligibility"
    ],
    "excluded": [
      "action_occurrence",
      "attempt",
      "canonical_human_state_write",
      "durable_target_form",
      "episode",
      "intent",
      "long_term_memory",
      "narrative",
      "performance",
      "world_outcome"
    ]
  },
  "type_catalog": [
    { "type_id": "ExternalOccurrence", "kind": "OCCURRENCE", "persistence": "INPUT_IMMUTABLE" },
    { "type_id": "CurrentAccessOccurrence", "kind": "OCCURRENCE", "persistence": "INPUT_IMMUTABLE" },
    { "type_id": "DeclaredRuntimeViewReceipt", "kind": "VIEW", "persistence": "TRACE_ONLY" },
    { "type_id": "ReceptionCandidate", "kind": "CANDIDATE", "persistence": "ACCESS_LOCAL" },
    { "type_id": "SubjectiveEncounterFormCandidate", "kind": "CANDIDATE", "persistence": "ACCESS_LOCAL" },
    { "type_id": "InterpretationCandidateSet", "kind": "SET", "persistence": "ACCESS_LOCAL" },
    { "type_id": "ScopedAdjudicationReceipt", "kind": "RECEIPT", "persistence": "TRACE_ONLY" },
    { "type_id": "ImmediateSurfaceProjectionCandidate", "kind": "CANDIDATE", "persistence": "ACCESS_LOCAL" },
    { "type_id": "RevisionCandidateOccurrence", "kind": "OCCURRENCE", "persistence": "TRACE_ONLY" },
    { "type_id": "RevisionEligibilityDecisionReceipt", "kind": "RECEIPT", "persistence": "TRACE_ONLY" },
    { "type_id": "RevisionReadReceipt", "kind": "RECEIPT", "persistence": "TRACE_ONLY" },
    { "type_id": "AccessLocalApplicationReceipt", "kind": "RECEIPT", "persistence": "TRACE_ONLY" },
    { "type_id": "RetentionObservationReceipt", "kind": "RECEIPT", "persistence": "TRACE_ONLY" }
  ],
  "runtime_view": {
    "materialized_type": "DeclaredRuntimeViewReceipt",
    "allowed_fields": [
      "current_access_occurrence",
      "evidence_assessment_digest",
      "external_evidence_link_set_digest",
      "interpretation_scope_id",
      "prior_eligible_revision_receipts",
      "runtime_id",
      "target_scope_id"
    ],
    "undeclared_field_policy": "HARD_REJECT",
    "human_state_read_policy": "NO_WHOLE_STATE_READ"
  },
  "stages": [
    {
      "stage_id": "MATERIALIZE_DECLARED_VIEW",
      "reads": ["CurrentAccessOccurrence", "ExternalOccurrence", "registered_view_fields"],
      "emits": ["DeclaredRuntimeViewReceipt"],
      "may_write": ["detached_trace"],
      "must_not_write": ["Evidence", "HumanState", "Narrative", "Episode", "TargetForm"]
    },
    {
      "stage_id": "FORM_RECEPTION_CANDIDATE",
      "reads": ["DeclaredRuntimeViewReceipt"],
      "emits": ["ReceptionCandidate"],
      "may_write": ["detached_trace"],
      "must_not_write": ["Evidence", "HumanState", "Narrative", "Episode", "TargetForm"]
    },
    {
      "stage_id": "FORM_SUBJECTIVE_ENCOUNTER",
      "reads": ["DeclaredRuntimeViewReceipt", "ReceptionCandidate"],
      "emits": ["SubjectiveEncounterFormCandidate"],
      "may_write": ["detached_trace"],
      "must_not_write": ["Evidence", "HumanState", "Narrative", "Episode", "TargetForm"]
    },
    {
      "stage_id": "EMIT_INTERPRETATION_CANDIDATES",
      "reads": ["DeclaredRuntimeViewReceipt", "SubjectiveEncounterFormCandidate"],
      "emits": ["InterpretationCandidateSet"],
      "may_write": ["detached_trace"],
      "must_not_write": ["Evidence", "HumanState", "Narrative", "Episode", "TargetForm"]
    },
    {
      "stage_id": "ADJUDICATE_SCOPED_CANDIDATES",
      "reads": ["InterpretationCandidateSet", "target_scope_id", "interpretation_scope_id"],
      "emits": ["ScopedAdjudicationReceipt"],
      "may_write": ["detached_trace"],
      "must_not_write": ["Evidence", "HumanState", "Narrative", "Episode", "TargetForm"]
    },
    {
      "stage_id": "PROJECT_IMMEDIATE_SURFACE",
      "reads": ["ScopedAdjudicationReceipt", "projection_strategy"],
      "emits": ["ImmediateSurfaceProjectionCandidate"],
      "may_write": ["detached_trace"],
      "must_not_write": ["ActionOccurrence", "Attempt", "Evidence", "HumanState", "Intent", "Narrative", "Episode", "Performance", "TargetForm", "WorldOutcome"]
    },
    {
      "stage_id": "DECIDE_REVISION_ELIGIBILITY",
      "reads": ["ScopedAdjudicationReceipt", "temporal_strategy"],
      "emits": ["RevisionCandidateOccurrence", "RevisionEligibilityDecisionReceipt"],
      "may_write": ["detached_trace"],
      "must_not_write": ["Evidence", "HumanState", "Narrative", "Episode", "TargetForm"]
    }
  ],
  "revision_lifecycle": {
    "decision_statuses": [
      "ELIGIBLE_FROM_FUTURE_ACCESS",
      "NOT_EMITTED",
      "NOT_ELIGIBLE",
      "REJECTED_BY_POLICY",
      "NOT_APPLICABLE_TO_MODEL"
    ],
    "ordered_types": [
      "RevisionCandidateOccurrence",
      "ScopedAdjudicationReceipt",
      "RevisionEligibilityDecisionReceipt",
      "RevisionReadReceipt",
      "AccessLocalApplicationReceipt",
      "RetentionObservationReceipt"
    ],
    "retention_rule": "RETENTION_REQUIRES_LATER_ACCESS_OBSERVATION"
  },
  "temporal_invariants": [
    {
      "invariant_id": "SAME_RUNTIME",
      "relation": "revision.runtime_id == read.runtime_id",
      "failure_class": "HARD_INVARIANT_FAILURE"
    },
    {
      "invariant_id": "SAME_TARGET_SCOPE",
      "relation": "revision.target_scope_id == read.target_scope_id",
      "failure_class": "HARD_INVARIANT_FAILURE"
    },
    {
      "invariant_id": "SAME_INTERPRETATION_SCOPE",
      "relation": "revision.interpretation_scope_id == read.interpretation_scope_id",
      "failure_class": "HARD_INVARIANT_FAILURE"
    },
    {
      "invariant_id": "FUTURE_ACCESS_ONLY",
      "relation": "revision.source_access_ordinal < read.access_ordinal",
      "failure_class": "HARD_INVARIANT_FAILURE"
    },
    {
      "invariant_id": "EFFECTIVE_BEFORE_READ",
      "relation": "revision.effective_from_ordinal <= read.access_ordinal",
      "failure_class": "HARD_INVARIANT_FAILURE"
    },
    {
      "invariant_id": "NO_SAME_ACCESS_FEEDBACK",
      "relation": "revision_at_k does not alter encounter candidate adjudication or surface digests at k",
      "failure_class": "AUTHORITY_FAILURE"
    }
  ],
  "forbidden_authorities": [
    "actual_human_or_llm_acquisition",
    "canonical_human_state_mutation",
    "claim_support_change",
    "durable_target_form_write",
    "episode_or_narrative_write",
    "evidence_write",
    "human_mechanism_inference",
    "intent_or_action_emission"
  ]
}

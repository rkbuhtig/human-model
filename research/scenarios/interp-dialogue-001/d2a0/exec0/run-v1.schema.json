{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/human-model/interp-001d2a0-exec0/run-v1.schema.json",
  "title": "INTERP-001D2a1 detached run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id", "contract_id", "predecessor_manifest_sha256",
    "exec0_manifest_sha256", "operator_catalog_sha256",
    "execution_unit_manifest_sha256", "runner_semantics_id", "traces", "summary"
  ],
  "properties": {
    "run_id": { "$ref": "#/$defs/token" },
    "contract_id": { "const": "INTERP-001D2A0-EXEC0-V0" },
    "predecessor_manifest_sha256": { "const": "8ee62993fbf302d8037f8cf898a0edca4fe7bbff7b01f73f6a71e8b6c04c3efd" },
    "exec0_manifest_sha256": { "$ref": "#/$defs/sha256" },
    "operator_catalog_sha256": { "$ref": "#/$defs/sha256" },
    "execution_unit_manifest_sha256": { "$ref": "#/$defs/sha256" },
    "runner_semantics_id": { "const": "INTERP-001D2A0-EXEC0-OPERATORS-V0" },
    "traces": {
      "type": "array",
      "items": { "$ref": "./trace-v1.schema.json" },
      "minItems": 46,
      "maxItems": 46,
      "uniqueItems": true
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registered_unit_count", "completed_unit_count", "rejected_unit_count", "aborted_unit_count"],
      "properties": {
        "registered_unit_count": { "const": 46 },
        "completed_unit_count": { "type": "integer", "minimum": 0, "maximum": 46 },
        "rejected_unit_count": { "type": "integer", "minimum": 0, "maximum": 46 },
        "aborted_unit_count": { "const": 0 }
      }
    }
  },
  "$defs": {
    "token": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}

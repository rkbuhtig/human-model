{
  "$schema": "./contract.schema.json",
  "document_kind": "lifecycle_processor",
  "schema_version": "1.0.0",
  "contract_id": "INTERP-001D2A0-EXEC0-V0",
  "status": "FROZEN_UNEXECUTED",
  "predecessor_manifest_sha256": "8ee62993fbf302d8037f8cf898a0edca4fe7bbff7b01f73f6a71e8b6c04c3efd",
  "payload": {
    "processor_id": "REVISION-LIFECYCLE-PROCESSOR-V0",
    "separation_rule": "INTERPRETATION_STAGES_DO_NOT_EMIT_READ_APPLICATION_OR_RETENTION_RECEIPTS",
    "dependency_order": [
      "ScopedAdjudicationReceipt",
      "RevisionCandidateOccurrence",
      "RevisionEligibilityDecisionReceipt",
      "RevisionReadReceipt",
      "AccessLocalApplicationReceipt",
      "RetentionObservationReceipt"
    ],
    "steps": [
      {
        "step_id": "READ_ELIGIBLE_REVISION",
        "reads": ["RevisionEligibilityDecisionReceipt", "CurrentAccessOccurrence", "DeclaredRuntimeViewReceipt"],
        "emits": ["RevisionReadReceipt"],
        "cardinality": "ZERO_OR_ONE_PER_ELIGIBILITY_PER_ACCESS",
        "authority_rules": ["SAME_RUNTIME", "SAME_TARGET_SCOPE", "SAME_INTERPRETATION_SCOPE", "FUTURE_ACCESS_ONLY", "EFFECTIVE_BEFORE_READ"]
      },
      {
        "step_id": "APPLY_REVISION_FOR_ACCESS",
        "reads": ["RevisionReadReceipt", "DeclaredRuntimeViewReceipt"],
        "emits": ["AccessLocalApplicationReceipt"],
        "cardinality": "ZERO_OR_ONE_PER_READ",
        "authority_rules": ["APPLICATION_IS_ACCESS_LOCAL", "READ_DOES_NOT_IMPLY_APPLICATION"]
      },
      {
        "step_id": "OBSERVE_RETENTION",
        "reads": ["AccessLocalApplicationReceipt", "LaterCurrentAccessOccurrence"],
        "emits": ["RetentionObservationReceipt"],
        "cardinality": "ZERO_OR_ONE_PER_APPLICATION_PER_LATER_ACCESS",
        "authority_rules": ["RETENTION_REQUIRES_STRICTLY_LATER_ACCESS", "APPLICATION_DOES_NOT_IMPLY_RETENTION"]
      }
    ],
    "typed_rejection_codes": [
      "SAME_ACCESS_REVISION_FEEDBACK",
      "REVISION_NOT_YET_EFFECTIVE",
      "CROSS_RUNTIME_REVISION_READ",
      "CROSS_TARGET_SCOPE_REVISION_READ",
      "CROSS_INTERPRETATION_SCOPE_REVISION_READ",
      "UNDECLARED_RUNTIME_VIEW_READ",
      "UNREGISTERED_FREE_CANDIDATE",
      "UNBOUNDED_OUT_OF_MODEL_ESCAPE"
    ],
    "terminal_semantics": {
      "typed_policy_rejection": "TERMINATE_UNIT_AND_CONTINUE_RUN",
      "malformed_contract_or_digest": "ABORT_WHOLE_RUN",
      "unknown_operator": "ABORT_WHOLE_RUN"
    }
  }
}

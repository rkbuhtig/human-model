        "forbidden_reads": ["role", "evaluation_manifest"],
        "forbidden_writes": ["surface_code", "durable_target_form"],
        "semantics": ["ADVERSE increments count capped at declared limit", "non-ADVERSE resets count to zero", "adjudicated_path equals reception_path", "count below limit emits NOT_ELIGIBLE and no revision_path", "count at limit emits ELIGIBLE_FROM_FUTURE_ACCESS with PATH-ADVERSE effective at source ordinal plus one"]
      },
      {
        "operator_id": "D2A-T3-REVISE",
        "axis_owner": "T",
        "opcode": "FUTURE_EFFECTIVE_RANK_MAX",

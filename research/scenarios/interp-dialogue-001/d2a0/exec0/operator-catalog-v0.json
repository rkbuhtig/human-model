        "forbidden_reads": ["role", "prior_revision", "evaluation_manifest"],
        "forbidden_writes": ["surface_code", "retained_state"],
        "semantics": ["OPEN preserves reception_path", "MASKED emits PATH-AMBIGUOUS", "revision_decision is NOT_APPLICABLE_TO_MODEL", "gate state is discarded at access close"]
      },
      {
        "operator_id": "D2A-T2-ACCUMULATE",
        "axis_owner": "T",
        "opcode": "BOUNDED_ADVERSE_COUNT",

        "forbidden_reads": ["role", "evaluation_manifest"],
        "forbidden_writes": ["surface_code", "durable_target_form"],
        "semantics": ["missing prior revision uses reception_path", "present prior revision uses max under path_rank_order", "revision_path equals adjudicated_path", "revision_decision is ELIGIBLE_FROM_FUTURE_ACCESS effective at source ordinal plus one"]
      },
      {
        "operator_id": "D2A-P0-DIRECT",
        "axis_owner": "P",

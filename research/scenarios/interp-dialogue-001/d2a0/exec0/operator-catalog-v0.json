        "emits": ["reception_path"],
        "forbidden_reads": ["role", "evaluation_manifest", "expected_relation"],
        "forbidden_writes": ["Evidence", "revision_decision", "surface_code"],
        "semantics": [
          "NEUTRAL preserves path",
          "POSITIVE maps BENIGN->BENIGN AMBIGUOUS->BENIGN ADVERSE->AMBIGUOUS",
          "NEGATIVE maps BENIGN->AMBIGUOUS AMBIGUOUS->ADVERSE ADVERSE->ADVERSE"
        ]
      },

        "forbidden_reads": ["role", "revision_decision", "evaluation_manifest"],
        "forbidden_writes": ["revision_decision", "revision_path"],
        "semantics": ["BENIGN maps SURFACE-OPEN", "AMBIGUOUS maps SURFACE-NEUTRAL", "ADVERSE maps SURFACE-GUARDED"]
      },
      {
        "operator_id": "D2A-P1-ROLE",
        "axis_owner": "P",
        "opcode": "ROLE_CONDITIONED_SURFACE_LOOKUP",
        "reads": ["adjudicated_path", "declared_surface_role"],
        "emits": ["surface_code"],
        "forbidden_reads": ["revision_decision", "evaluation_manifest"],
        "forbidden_writes": ["revision_decision", "revision_path"],
        "semantics": ["PRIVATE uses P0 direct lookup", "PUBLIC maps every path to SURFACE-NEUTRAL", "role has no revision or lifecycle authority"]
      }

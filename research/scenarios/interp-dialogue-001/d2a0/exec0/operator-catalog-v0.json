        "forbidden_reads": ["role", "evaluation_manifest", "expected_relation"],
        "forbidden_writes": ["revision_decision", "surface_code"],
        "semantics": [
          "HET-A binds NEUTRAL/PRESERVE/limit-2",
          "HET-B binds POSITIVE/PRESERVE/limit-2",
          "HET-C binds NEGATIVE/NARROW/limit-1",
          "undeclared profile is terminal contract failure"

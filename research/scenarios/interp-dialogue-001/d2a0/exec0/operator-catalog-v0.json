      "RevisionCandidateOccurrence": ["revision_path", "source_access_ordinal", "effective_from_ordinal"],
      "RevisionEligibilityDecisionReceipt": ["decision_status", "revision_path", "source_access_ordinal", "effective_from_ordinal"],
      "RevisionReadReceipt": ["read_status", "revision_record_id"],

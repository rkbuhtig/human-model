{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/human-model/interp-001d2a0/trace.schema.json",
  "title": "INTERP-001D2a detached trace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "contract_id",
    "execution_manifest_sha256",
    "cell_id",
    "fixture_id",
    "arm_id",
    "status",
    "records"
  ],
  "properties": {
    "trace_id": { "$ref": "#/$defs/token" },
    "contract_id": { "const": "INTERP-001D2A0-V0" },
    "execution_manifest_sha256": { "$ref": "#/$defs/sha256" },
    "cell_id": { "$ref": "#/$defs/token" },
    "fixture_id": { "$ref": "#/$defs/token" },
    "arm_id": { "$ref": "#/$defs/token" },
    "status": { "enum": ["COMPLETED", "REJECTED"] },
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/record" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "tokenList": {
      "type": "array",
      "items": { "$ref": "#/$defs/token" },
      "uniqueItems": true
    },
    "stageRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "type_id",
        "runtime_id",
        "target_scope_id",
        "interpretation_scope_id",
        "access_id",
        "access_ordinal",
        "writer_stage",
        "source_record_ids",
        "payload_digest",
        "external_evidence_link_set_digest",
        "evidence_assessment_digest",
        "subjective_path_digest"
      ],
      "properties": {
        "record_id": { "$ref": "#/$defs/token" },
        "type_id": {
          "enum": [
            "DeclaredRuntimeViewReceipt",
            "ReceptionCandidate",
            "SubjectiveEncounterFormCandidate",
            "InterpretationCandidateSet",
            "ScopedAdjudicationReceipt",
            "ImmediateSurfaceProjectionCandidate"
          ]
        },
        "runtime_id": { "$ref": "#/$defs/token" },
        "target_scope_id": { "$ref": "#/$defs/token" },
        "interpretation_scope_id": { "$ref": "#/$defs/token" },
        "access_id": { "$ref": "#/$defs/token" },
        "access_ordinal": { "type": "integer", "minimum": 1 },
        "writer_stage": { "$ref": "#/$defs/token" },
        "source_record_ids": { "$ref": "#/$defs/tokenList" },
        "payload_digest": { "$ref": "#/$defs/sha256" },
        "external_evidence_link_set_digest": { "$ref": "#/$defs/sha256" },
        "evidence_assessment_digest": { "$ref": "#/$defs/sha256" },
        "subjective_path_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "revisionCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id", "type_id", "runtime_id", "target_scope_id",
        "interpretation_scope_id", "access_id", "access_ordinal", "writer_stage",
        "source_record_ids", "payload_digest", "external_evidence_link_set_digest",
        "evidence_assessment_digest", "subjective_path_digest",
        "source_access_ordinal", "effective_from_ordinal"
      ],
      "properties": {
        "record_id": { "$ref": "#/$defs/token" },
        "type_id": { "const": "RevisionCandidateOccurrence" },
        "runtime_id": { "$ref": "#/$defs/token" },
        "target_scope_id": { "$ref": "#/$defs/token" },
        "interpretation_scope_id": { "$ref": "#/$defs/token" },
        "access_id": { "$ref": "#/$defs/token" },
        "access_ordinal": { "type": "integer", "minimum": 1 },
        "writer_stage": { "$ref": "#/$defs/token" },
        "source_record_ids": { "$ref": "#/$defs/tokenList" },
        "payload_digest": { "$ref": "#/$defs/sha256" },
        "external_evidence_link_set_digest": { "$ref": "#/$defs/sha256" },
        "evidence_assessment_digest": { "$ref": "#/$defs/sha256" },
        "subjective_path_digest": { "$ref": "#/$defs/sha256" },
        "source_access_ordinal": { "type": "integer", "minimum": 1 },
        "effective_from_ordinal": { "type": "integer", "minimum": 2 }
      }
    },
    "eligibilityReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id", "type_id", "runtime_id", "target_scope_id",
        "interpretation_scope_id", "access_id", "access_ordinal", "writer_stage",
        "source_record_ids", "payload_digest", "external_evidence_link_set_digest",
        "evidence_assessment_digest", "subjective_path_digest",
        "decision_status", "source_access_ordinal", "effective_from_ordinal"
      ],
      "properties": {
        "record_id": { "$ref": "#/$defs/token" },
        "type_id": { "const": "RevisionEligibilityDecisionReceipt" },
        "runtime_id": { "$ref": "#/$defs/token" },
        "target_scope_id": { "$ref": "#/$defs/token" },
        "interpretation_scope_id": { "$ref": "#/$defs/token" },
        "access_id": { "$ref": "#/$defs/token" },
        "access_ordinal": { "type": "integer", "minimum": 1 },
        "writer_stage": { "$ref": "#/$defs/token" },
        "source_record_ids": { "$ref": "#/$defs/tokenList" },
        "payload_digest": { "$ref": "#/$defs/sha256" },
        "external_evidence_link_set_digest": { "$ref": "#/$defs/sha256" },
        "evidence_assessment_digest": { "$ref": "#/$defs/sha256" },
        "subjective_path_digest": { "$ref": "#/$defs/sha256" },
        "decision_status": {
          "enum": [
            "ELIGIBLE_FROM_FUTURE_ACCESS", "NOT_EMITTED", "NOT_ELIGIBLE",
            "REJECTED_BY_POLICY", "NOT_APPLICABLE_TO_MODEL"
          ]
        },
        "source_access_ordinal": { "type": "integer", "minimum": 1 },
        "effective_from_ordinal": { "type": "integer", "minimum": 2 }
      }
    },
    "readReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id", "type_id", "runtime_id", "target_scope_id",
        "interpretation_scope_id", "access_id", "access_ordinal", "writer_stage",
        "source_record_ids", "payload_digest", "external_evidence_link_set_digest",
        "evidence_assessment_digest", "subjective_path_digest", "revision_record_id",
        "source_access_ordinal", "effective_from_ordinal", "read_status"
      ],
      "properties": {
        "record_id": { "$ref": "#/$defs/token" },
        "type_id": { "const": "RevisionReadReceipt" },
        "runtime_id": { "$ref": "#/$defs/token" },
        "target_scope_id": { "$ref": "#/$defs/token" },
        "interpretation_scope_id": { "$ref": "#/$defs/token" },
        "access_id": { "$ref": "#/$defs/token" },
        "access_ordinal": { "type": "integer", "minimum": 1 },
        "writer_stage": { "$ref": "#/$defs/token" },
        "source_record_ids": { "$ref": "#/$defs/tokenList" },
        "payload_digest": { "$ref": "#/$defs/sha256" },
        "external_evidence_link_set_digest": { "$ref": "#/$defs/sha256" },
        "evidence_assessment_digest": { "$ref": "#/$defs/sha256" },
        "subjective_path_digest": { "$ref": "#/$defs/sha256" },
        "revision_record_id": { "$ref": "#/$defs/token" },
        "source_access_ordinal": { "type": "integer", "minimum": 1 },
        "effective_from_ordinal": { "type": "integer", "minimum": 2 },
        "read_status": { "enum": ["READ", "NOT_READ"] }
      }
    },
    "applicationReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id", "type_id", "runtime_id", "target_scope_id",
        "interpretation_scope_id", "access_id", "access_ordinal", "writer_stage",
        "source_record_ids", "payload_digest", "external_evidence_link_set_digest",
        "evidence_assessment_digest", "subjective_path_digest", "read_record_id",
        "application_status"
      ],
      "properties": {
        "record_id": { "$ref": "#/$defs/token" },
        "type_id": { "const": "AccessLocalApplicationReceipt" },
        "runtime_id": { "$ref": "#/$defs/token" },
        "target_scope_id": { "$ref": "#/$defs/token" },
        "interpretation_scope_id": { "$ref": "#/$defs/token" },
        "access_id": { "$ref": "#/$defs/token" },
        "access_ordinal": { "type": "integer", "minimum": 1 },
        "writer_stage": { "$ref": "#/$defs/token" },
        "source_record_ids": { "$ref": "#/$defs/tokenList" },
        "payload_digest": { "$ref": "#/$defs/sha256" },
        "external_evidence_link_set_digest": { "$ref": "#/$defs/sha256" },
        "evidence_assessment_digest": { "$ref": "#/$defs/sha256" },
        "subjective_path_digest": { "$ref": "#/$defs/sha256" },
        "read_record_id": { "$ref": "#/$defs/token" },
        "application_status": { "enum": ["APPLIED_FOR_ACCESS", "READ_NOT_APPLIED"] }
      }
    },
    "retentionReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id", "type_id", "runtime_id", "target_scope_id",
        "interpretation_scope_id", "access_id", "access_ordinal", "writer_stage",
        "source_record_ids", "payload_digest", "external_evidence_link_set_digest",
        "evidence_assessment_digest", "subjective_path_digest",
        "prior_application_record_id", "observation_status"
      ],
      "properties": {
        "record_id": { "$ref": "#/$defs/token" },
        "type_id": { "const": "RetentionObservationReceipt" },
        "runtime_id": { "$ref": "#/$defs/token" },
        "target_scope_id": { "$ref": "#/$defs/token" },
        "interpretation_scope_id": { "$ref": "#/$defs/token" },
        "access_id": { "$ref": "#/$defs/token" },
        "access_ordinal": { "type": "integer", "minimum": 2 },
        "writer_stage": { "$ref": "#/$defs/token" },
        "source_record_ids": { "$ref": "#/$defs/tokenList" },
        "payload_digest": { "$ref": "#/$defs/sha256" },
        "external_evidence_link_set_digest": { "$ref": "#/$defs/sha256" },
        "evidence_assessment_digest": { "$ref": "#/$defs/sha256" },
        "subjective_path_digest": { "$ref": "#/$defs/sha256" },
        "prior_application_record_id": { "$ref": "#/$defs/token" },
        "observation_status": { "enum": ["OBSERVED_RETAINED", "OBSERVED_NOT_RETAINED"] }
      }
    },
    "record": {
      "oneOf": [
        { "$ref": "#/$defs/stageRecord" },
        { "$ref": "#/$defs/revisionCandidate" },
        { "$ref": "#/$defs/eligibilityReceipt" },
        { "$ref": "#/$defs/readReceipt" },
        { "$ref": "#/$defs/applicationReceipt" },
        { "$ref": "#/$defs/retentionReceipt" }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rkbuhtig/human-model/research/scenarios/interp-dialogue-001/trace-oracle.schema.json",
  "title": "INTERP-DIALOGUE-001B functional-placement trace oracle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema", "study_id", "oracle_id", "version", "status", "authority",
    "bound_family_files", "observation_points", "horizons", "trace_fields",
    "relation_vocabulary", "observation_vocabulary", "adjudication_vocabulary",
    "placement_catalog", "guard_policy_catalog", "prefix_extension_guard", "factor_oracles", "matched_future_oracles",
    "rel_delayed_reorganization_factorial", "d2a_only_challenges",
    "operational_alias_rule", "out_of_model_policy", "prohibitions"
  ],
  "properties": {
    "$schema": {"const": "./trace-oracle.schema.json"},
    "study_id": {"const": "INTERP-DIALOGUE-001B"},
    "oracle_id": {"const": "INTERP-DIALOGUE-001B-TRACE-ORACLE-V1"},
    "version": {"const": "1.0.0"},
    "status": {"const": "INTERNAL_PREREGISTRATION_UNEXECUTED_NO_HUMAN_LLM_OR_D2A_TRACE_DATA"},
    "authority": {"$ref": "#/$defs/authority"},
    "bound_family_files": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {"$ref": "#/$defs/familyBinding"}, "uniqueItems": true
    },
    "observation_points": {
      "type": "array", "minItems": 11, "maxItems": 11,
      "items": {"$ref": "#/$defs/observationPoint"}, "uniqueItems": true
    },
    "horizons": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {"$ref": "#/$defs/horizon"}, "uniqueItems": true
    },
    "trace_fields": {
      "type": "array", "minItems": 1,
      "items": {"$ref": "#/$defs/traceField"}, "uniqueItems": true
    },
    "relation_vocabulary": {
      "type": "array", "minItems": 8, "maxItems": 8,
      "items": {"$ref": "#/$defs/relationTerm"}, "uniqueItems": true
    },
    "observation_vocabulary": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"$ref": "#/$defs/observationTerm"}, "uniqueItems": true
    },
    "adjudication_vocabulary": {"$ref": "#/$defs/uniqueStringList"},
    "placement_catalog": {
      "type": "array", "minItems": 1,
      "items": {"$ref": "#/$defs/placementFamily"}, "uniqueItems": true
    },
    "guard_policy_catalog": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"$ref": "#/$defs/guardPolicy"}, "uniqueItems": true
    },
    "prefix_extension_guard": {"$ref": "#/$defs/prefixExtensionGuard"},
    "factor_oracles": {
      "type": "array", "minItems": 9, "maxItems": 9,
      "items": {"$ref": "#/$defs/factorOracle"}, "uniqueItems": true
    },
    "matched_future_oracles": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {"$ref": "#/$defs/futureOracle"}, "uniqueItems": true
    },
    "rel_delayed_reorganization_factorial": {"$ref": "#/$defs/relFactorial"},
    "d2a_only_challenges": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "items": {"$ref": "#/$defs/d2aChallenge"}, "uniqueItems": true
    },
    "operational_alias_rule": {"$ref": "#/$defs/aliasRule"},
    "out_of_model_policy": {"$ref": "#/$defs/outOfModelPolicy"},
    "prohibitions": {"$ref": "#/$defs/uniqueStringList"}
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "token": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]*$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "uniqueStringList": {
      "type": "array", "minItems": 1,
      "items": {"$ref": "#/$defs/nonEmptyString"}, "uniqueItems": true
    },
    "tokenList": {
      "type": "array", "items": {"$ref": "#/$defs/token"}, "uniqueItems": true
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_role", "source_status", "empirical_status", "execution_status", "mechanism_status", "output_status"],
      "properties": {
        "artifact_role": {"const": "FUNCTIONAL_JURISDICTION_TRACE_ORACLE"},
        "source_status": {"const": "AUTHOR_ORIGIN_METHOD_CONTRACT"},
        "empirical_status": {"const": "NO_HUMAN_LLM_OR_D2A_TRACE_DATA"},
        "execution_status": {"const": "UNEXECUTED"},
        "mechanism_status": {"const": "COMPETING_PLACEMENTS_OPEN"},
        "output_status": {"const": "NO_OBSERVED_TRACE_OR_PLACEMENT_RESULT"}
      }
    },
    "familyBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["family_id", "path", "content_sha256"],
      "properties": {
        "family_id": {"$ref": "#/$defs/token"},
        "path": {"$ref": "#/$defs/nonEmptyString"},
        "content_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "observationPoint": {
      "type": "object", "additionalProperties": false,
      "required": ["observation_point_id", "horizon_id", "ordinal", "stage", "authority", "description"],
      "properties": {
        "observation_point_id": {"$ref": "#/$defs/token"},
        "horizon_id": {"$ref": "#/$defs/token"},
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 10},
        "stage": {"enum": ["PREFIX", "ACCESS", "ENCOUNTER", "CANDIDATE", "ADJUDICATION", "SURFACE", "FUTURE_PROBE_PREFIX", "LATER_FUNCTIONAL_PROJECTION"]},
        "authority": {"enum": ["OBSERVATION_SLOT_NOT_RESULT", "OBSERVATION_SLOT_NOT_DESIGN_ANCHOR"]},
        "description": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "horizon": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["horizon_id", "ordinal_relation", "start_observation_point_id", "end_observation_point_id", "authority", "future_probe_count", "later_processing_opportunity_count"],
          "properties": {
            "horizon_id": {"const": "H_PREFIX_BEFORE_K"},
            "ordinal_relation": {"const": "PREFIX_BEFORE_K"},
            "start_observation_point_id": {"$ref": "#/$defs/token"},
            "end_observation_point_id": {"$ref": "#/$defs/token"},
            "authority": {"const": "FROZEN_PREFIX_SCOPE_NOT_EMPIRICAL_RESULT"},
            "future_probe_count": {"const": 0},
            "later_processing_opportunity_count": {"const": 0}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["horizon_id", "ordinal_relation", "start_observation_point_id", "end_observation_point_id", "authority", "future_probe_count", "later_processing_opportunity_count"],
          "properties": {
            "horizon_id": {"const": "H_INITIAL_ACCESS_K"},
            "ordinal_relation": {"const": "INITIAL_ACCESS_K"},
            "start_observation_point_id": {"$ref": "#/$defs/token"},
            "end_observation_point_id": {"$ref": "#/$defs/token"},
            "authority": {"const": "FROZEN_INITIAL_SCOPE_NOT_EMPIRICAL_RESULT"},
            "future_probe_count": {"const": 0},
            "later_processing_opportunity_count": {"const": 0}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["horizon_id", "ordinal_relation", "start_observation_point_id", "end_observation_point_id", "authority", "future_probe_count", "later_processing_opportunity_count", "same_option_requirement"],
          "properties": {
            "horizon_id": {"const": "H_REGISTERED_FUTURE_ACCESS_K_PLUS_1"},
            "ordinal_relation": {"const": "REGISTERED_FUTURE_ACCESS_K_PLUS_1"},
            "start_observation_point_id": {"$ref": "#/$defs/token"},
            "end_observation_point_id": {"$ref": "#/$defs/token"},
            "authority": {"const": "FROZEN_ONE_FUTURE_PROBE_SCOPE_NOT_EMPIRICAL_RESULT"},
            "future_probe_count": {"const": 1},
            "later_processing_opportunity_count": {"const": 1},
            "same_option_requirement": {"const": "THE_SAME_REGISTERED_FUTURE_OPTION_ID_IS_APPLIED_TO_BOTH_PRIOR_PATHS"}
          }
        }
      ]
    },
    "traceField": {
      "type": "object", "additionalProperties": false,
      "required": ["trace_field_id", "field_role", "authority"],
      "properties": {
        "trace_field_id": {"$ref": "#/$defs/token"},
        "field_role": {"enum": ["BASE_PUBLIC_RECORD", "DECLARED_LEVEL_PUBLIC_RECORD", "DECLARED_FUTURE_OPTION_RECORD", "WORLD_UNKNOWNS", "FUNCTIONAL_TRACE", "PREFIX_GUARD", "FORBIDDEN_CAST_GUARD", "EVIDENCE_LINK_SET", "EVIDENCE_LEDGER"]},
        "authority": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "relationTerm": {
      "type": "object", "additionalProperties": false,
      "required": ["relation", "meaning"],
      "properties": {
        "relation": {"enum": ["MUST_REMAIN_EQUAL", "MUST_DIFFER_IF_PLACEMENT", "MAY_DIFFER_DOWNSTREAM", "MUST_DIFFER_BY_DESIGN", "MAY_DIFFER_WITH_DECLARED_PUBLIC_INPUT", "MUST_REMAIN_ABSENT", "NOT_EVALUABLE_WITHOUT_FROZEN_REASSESSMENT_POLICY", "RELATION_NOT_APPLICABLE"]},
        "meaning": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "observationTerm": {
      "type": "object", "additionalProperties": false,
      "required": ["observation", "meaning"],
      "properties": {
        "observation": {"enum": ["EQUAL", "DIFFERENT", "NOT_OBSERVED", "OBSERVATION_NOT_APPLICABLE"]},
        "meaning": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "projectionRef": {
      "type": "object", "additionalProperties": false,
      "required": ["observation_point_id", "trace_field_id"],
      "properties": {
        "observation_point_id": {"$ref": "#/$defs/token"},
        "trace_field_id": {"$ref": "#/$defs/token"}
      }
    },
    "relation": {
      "type": "object", "additionalProperties": false,
      "required": ["observation_point_id", "trace_field_id", "relation"],
      "properties": {
        "observation_point_id": {"$ref": "#/$defs/token"},
        "trace_field_id": {"$ref": "#/$defs/token"},
        "relation": {"enum": ["MUST_REMAIN_EQUAL", "MUST_DIFFER_IF_PLACEMENT", "MAY_DIFFER_DOWNSTREAM", "MUST_DIFFER_BY_DESIGN", "MAY_DIFFER_WITH_DECLARED_PUBLIC_INPUT", "MUST_REMAIN_ABSENT", "NOT_EVALUABLE_WITHOUT_FROZEN_REASSESSMENT_POLICY", "RELATION_NOT_APPLICABLE"]}
      }
    },
    "placement": {
      "type": "object", "additionalProperties": false,
      "required": ["placement_id", "label", "authority"],
      "properties": {
        "placement_id": {"$ref": "#/$defs/token"},
        "label": {"$ref": "#/$defs/nonEmptyString"},
        "candidate_kind": {"enum": ["DURABLE_TARGET_SCOPED_STATE_CANDIDATE", "SLOW_CACHE_READOUT_CANDIDATE"]},
        "identifiability_status": {"const": "NOT_IDENTIFIABLE_UNDER_CURRENT_HORIZON"},
        "authority": {"enum": ["COMPETING_FUNCTIONAL_PLACEMENT_NOT_RESULT", "HYPOTHESIS_CANDIDATE_NO_WRITER_RETENTION_OR_EXISTENCE_CLAIM"]}
      }
    },
    "horizonLimitation": {
      "type": "object", "additionalProperties": false,
      "required": ["placement_ids", "horizon_id", "status", "precedence", "forbidden_conclusions"],
      "properties": {
        "placement_ids": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {"$ref": "#/$defs/token"}, "uniqueItems": true
        },
        "horizon_id": {"$ref": "#/$defs/token"},
        "status": {"const": "NOT_IDENTIFIABLE_UNDER_HORIZON"},
        "precedence": {"const": "HORIZON_LIMITATION_OVERRIDES_GENERAL_ALIAS_RULE"},
        "forbidden_conclusions": {"$ref": "#/$defs/uniqueStringList"}
      }
    },
    "placementFamily": {
      "type": "object", "additionalProperties": false,
      "required": ["placement_family_id", "placements"],
      "properties": {
        "placement_family_id": {"$ref": "#/$defs/token"},
        "placements": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/placement"}, "uniqueItems": true
        },
        "horizon_limitation": {"$ref": "#/$defs/horizonLimitation"}
      }
    },
    "guardPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["guard_policy_id", "source_lane", "guard_projection_set", "unconditional_guard_relations"],
      "properties": {
        "guard_policy_id": {"enum": ["GUARD_FIRST_PERSON_CONDITION", "GUARD_DECLARED_PUBLIC_HISTORY_OR_STIMULUS", "GUARD_EXPERIMENTER_CUE", "GUARD_RISK_SEPARATE_HISTORY"]},
        "source_lane": {"enum": ["FIRST_PERSON_CONDITION_REPORT", "VIGNETTE_HISTORY_RECORD_OR_PUBLIC_STIMULUS_VARIANT", "EXPERIMENTER_CUE", "VIGNETTE_HISTORY_RECORD_CURRENT_SOURCE_SEPARATE"]},
        "link_equality_authority": {"const": "EQUALITY_DOES_NOT_ASSERT_MEMBERSHIP"},
        "source_material_prerequisite": {"const": "BOTH_PRIOR_SOURCE_MATERIALS_EXIST_BY_BOUND_001A_MINIMAL_PAIR_CONTRACT_WITHOUT_ASSERTING_EVIDENCE_LINK_MEMBERSHIP"},
        "evidence_assessment_scope": {"enum": ["EXTERNAL_TARGET_OR_CURRENT_SOURCE_CLAIMS_ONLY_EXCLUDES_FIRST_PERSON_CONDITION_ATTESTATION", "CURRENT_UNRESOLVED_FOOTSTEP_SOURCE_CLAIM_ONLY_SEPARATE_PRIOR_INCIDENT_CLAIM_IS_OUTSIDE_THIS_EQUALITY_GUARD"]},
        "guard_projection_set": {
          "type": "array", "minItems": 8, "maxItems": 8,
          "items": {"$ref": "#/$defs/projectionRef"}, "uniqueItems": true
        },
        "unconditional_guard_relations": {
          "type": "array", "minItems": 8, "maxItems": 8,
          "items": {"$ref": "#/$defs/relation"}, "uniqueItems": true
        }
      }
    },
    "prefixExtensionGuard": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "comparison_unit", "base_observation_point_id", "trace_field_id", "relation", "cross_factor_arm_equality_required", "protected_initial_trace_observation_point_ids", "initial_trace_comparison_unit", "initial_trace_relation", "initial_trace_digest_status_policy", "future_extension_append_rule", "execution_source_scope", "future_extension_rule", "forbidden_comparison"],
      "properties": {
        "status": {"const": "UNEXECUTED"},
        "comparison_unit": {"const": "SAME_ARM_SAME_O0_PREFIX_ARTIFACT_ACROSS_BASE_AND_FUTURE_EXTENSION_RUNS"},
        "base_observation_point_id": {"const": "O0_INPUT_ACCEPTED_PRE_ACCESS"},
        "trace_field_id": {"const": "prior_occurrence_prefix"},
        "relation": {"const": "MUST_REMAIN_EQUAL"},
        "cross_factor_arm_equality_required": {"const": false},
        "protected_initial_trace_observation_point_ids": {
          "type": "array", "minItems": 6, "maxItems": 6, "uniqueItems": true,
          "items": {"enum": ["O0_INPUT_ACCEPTED_PRE_ACCESS", "O1_INITIAL_ACCESS_WINDOW_CLOSED", "O2_INITIAL_ENCOUNTER_WINDOW_CLOSED", "O3_INITIAL_CANDIDATE_WINDOW_CLOSED", "O4_INITIAL_ADJUDICATION_WINDOW_CLOSED", "O5_IMMEDIATE_SURFACE_RECORDED"]}
        },
        "initial_trace_comparison_unit": {"const": "SAME_ARM_SAME_EMITTED_O0_TO_O5_TRACE_PREFIX_ACROSS_BASE_AND_FUTURE_EXTENSION_RUNS"},
        "initial_trace_relation": {"const": "MUST_REMAIN_EQUAL"},
        "initial_trace_digest_status_policy": {"const": "MISSING_OR_NOT_OBSERVED_STATUS_IS_PART_OF_FROZEN_DIGEST"},
        "future_extension_append_rule": {"const": "FUTURE_EXTENSION_ONLY_APPENDS_AFTER_O5_WITHOUT_REWRITING_EMITTED_INITIAL_TRACE"},
        "execution_source_scope": {"const": "D2A_OR_RUNTIME_REPLAY_ONLY_NOT_HUMAN_REEXPERIENCE"},
        "future_extension_rule": {"const": "FUTURE_EXTENSION_RUN_MUST_PRESERVE_THE_SAME_EMITTED_O0_PREFIX_ARTIFACT_FROM_ITS_TRUNCATED_BASE_RUN"},
        "forbidden_comparison": {"const": "O0_PREFIX_IS_NOT_COMPARED_FOR_EQUALITY_WITH_O6_PRE_FUTURE_PREFIX"}
      }
    },
    "factorSnapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["source_lane", "held_constant_factor_ids", "public_record_effect", "registered_candidate_probe_domains", "must_remain_equal", "open_discriminator_refs", "status"],
      "properties": {
        "source_lane": {"$ref": "#/$defs/nonEmptyString"},
        "held_constant_factor_ids": {"$ref": "#/$defs/tokenList"},
        "public_record_effect": {"$ref": "#/$defs/nonEmptyString"},
        "registered_candidate_probe_domains": {"$ref": "#/$defs/uniqueStringList"},
        "must_remain_equal": {"$ref": "#/$defs/uniqueStringList"},
        "open_discriminator_refs": {"$ref": "#/$defs/tokenList"},
        "status": {"const": "OPEN_NO_EXPECTED_TRACE"}
      }
    },
    "contrastScope": {
      "type": "object", "additionalProperties": false,
      "required": ["changed_public_record", "same_option_pairing"],
      "properties": {
        "changed_public_record": {"const": "DECLARED_FACTOR_LEVEL_RECORD_ONLY"},
        "same_option_pairing": {"const": "NOT_APPLICABLE"}
      }
    },
    "hypothesis": {
      "type": "object", "additionalProperties": false,
      "required": ["hypothesis_id", "placement_id", "authority", "direct_edge_claim", "d2a_challenge_refs", "relations"],
      "properties": {
        "hypothesis_id": {"$ref": "#/$defs/token"},
        "placement_id": {"$ref": "#/$defs/token"},
        "authority": {"const": "HYPOTHESIS_DEFINITION_NOT_EMPIRICAL_EXPECTATION"},
        "direct_edge_claim": {"enum": ["NONE", "D2A_NODE_CLAMP_REQUIRED"]},
        "d2a_challenge_refs": {"$ref": "#/$defs/tokenList"},
        "relations": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/relation"}, "uniqueItems": true
        }
      }
    },
    "factorOracle": {
      "type": "object", "additionalProperties": false,
      "required": ["oracle_id", "family_id", "factor_id", "source_contract_snapshot", "placement_family_id", "guard_policy_id", "contrast_scope", "projection_set", "hypotheses"],
      "properties": {
        "oracle_id": {"$ref": "#/$defs/token"},
        "family_id": {"$ref": "#/$defs/token"},
        "factor_id": {"$ref": "#/$defs/token"},
        "source_contract_snapshot": {"$ref": "#/$defs/factorSnapshot"},
        "placement_family_id": {"$ref": "#/$defs/token"},
        "guard_policy_id": {"$ref": "#/$defs/token"},
        "contrast_scope": {"$ref": "#/$defs/contrastScope"},
        "projection_set": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/projectionRef"}, "uniqueItems": true
        },
        "hypotheses": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/hypothesis"}, "uniqueItems": true
        },
        "adjacent_evidence_lane_rule": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "futureProbeSnapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["probe_id", "probe_options", "open_question", "distinct_path_requirement", "no_expected_result"],
      "properties": {
        "probe_id": {"$ref": "#/$defs/token"},
        "probe_options": {"$ref": "#/$defs/uniqueStringList"},
        "open_question": {"$ref": "#/$defs/nonEmptyString"},
        "distinct_path_requirement": {"$ref": "#/$defs/nonEmptyString"},
        "no_expected_result": {"const": true}
      }
    },
    "sameSurfaceEligibility": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "observation_point_id", "trace_field_id", "allowed_bases", "required_scope_keys", "clamp_authority", "forbidden_basis", "failure_status"],
      "properties": {
        "status": {"const": "UNEXECUTED"},
        "observation_point_id": {"const": "O5_IMMEDIATE_SURFACE_RECORDED"},
        "trace_field_id": {"const": "immediate_surface"},
        "allowed_bases": {
          "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true,
          "items": {"enum": ["ACTUAL_ELICITED_SURFACE_OBSERVED_EQUAL_UNDER_FROZEN_SOURCE_SPECIFIC_MAPPING", "PREREGISTERED_NO_FEEDBACK_SURFACE_CLAMP_EQUAL"]}
        },
        "required_scope_keys": {
          "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true,
          "items": {"enum": ["source_kind", "measurement_mapping_version", "elicitation_protocol_version"]}
        },
        "clamp_authority": {"const": "D2A_ONLY_PREREGISTERED_NO_FEEDBACK_SURFACE_CLAMP"},
        "forbidden_basis": {"const": "DESIGN_ANCHOR_ONLY"},
        "failure_status": {"const": "NOT_EVALUABLE"}
      }
    },
    "matchedOptionArm": {
      "type": "object", "additionalProperties": false,
      "required": ["option_index", "left_prior_cell_id", "right_prior_cell_id", "left_option_index", "right_option_index"],
      "properties": {
        "option_index": {"type": "integer", "minimum": 0},
        "left_prior_cell_id": {"$ref": "#/$defs/token"},
        "right_prior_cell_id": {"$ref": "#/$defs/token"},
        "left_option_index": {"type": "integer", "minimum": 0},
        "right_option_index": {"type": "integer", "minimum": 0}
      }
    },
    "futureOracle": {
      "type": "object", "additionalProperties": false,
      "required": ["oracle_id", "family_id", "source_probe_id", "source_option_count", "compared_prior_cell_ids", "changed_factor_id", "candidate_anchor_authority", "comparison_rule", "same_surface_eligibility", "matched_option_arms", "source_probe_snapshot", "later_projection_refs", "future_guard_projection_set", "future_guard_relations"],
      "properties": {
        "oracle_id": {"$ref": "#/$defs/token"},
        "family_id": {"$ref": "#/$defs/token"},
        "source_probe_id": {"$ref": "#/$defs/token"},
        "source_option_count": {"type": "integer", "minimum": 2},
        "compared_prior_cell_ids": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {"$ref": "#/$defs/token"}, "uniqueItems": true
        },
        "changed_factor_id": {"$ref": "#/$defs/token"},
        "candidate_anchor_authority": {"const": "DESIGN_ONLY_NOT_OBSERVED_IMMEDIATE_SURFACE"},
        "comparison_rule": {"const": "SAME_FUTURE_OPTION_APPLIED_TO_BOTH_PRIOR_PATHS"},
        "same_surface_eligibility": {"$ref": "#/$defs/sameSurfaceEligibility"},
        "matched_option_arms": {
          "type": "array", "minItems": 2,
          "items": {"$ref": "#/$defs/matchedOptionArm"}, "uniqueItems": true
        },
        "source_probe_snapshot": {"$ref": "#/$defs/futureProbeSnapshot"},
        "later_projection_refs": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/projectionRef"}, "uniqueItems": true
        },
        "future_guard_projection_set": {
          "type": "array", "minItems": 6, "maxItems": 6,
          "items": {"$ref": "#/$defs/projectionRef"}, "uniqueItems": true
        },
        "future_guard_relations": {
          "type": "array", "minItems": 6, "maxItems": 6,
          "items": {"$ref": "#/$defs/relation"}, "uniqueItems": true
        }
      }
    },
    "factorialCell": {
      "type": "object", "additionalProperties": false,
      "required": ["trajectory_cell_id", "initial_cell_id", "initial_reported_mood", "later_option_id"],
      "properties": {
        "trajectory_cell_id": {"$ref": "#/$defs/token"},
        "initial_cell_id": {"$ref": "#/$defs/token"},
        "initial_reported_mood": {"$ref": "#/$defs/token"},
        "later_option_id": {"$ref": "#/$defs/token"}
      }
    },
    "laterOptionMapping": {
      "type": "object", "additionalProperties": false,
      "required": ["later_option_id", "source_option_index"],
      "properties": {
        "later_option_id": {"enum": ["later_reported_ordinary_mood", "later_reported_low_mood"]},
        "source_option_index": {"type": "integer", "minimum": 0, "maximum": 1}
      }
    },
    "factorialEdgeClass": {
      "type": "object", "additionalProperties": false,
      "required": ["edge_class_id", "pairs", "meaning"],
      "properties": {
        "edge_class_id": {"enum": ["INITIAL_MOOD_EDGE_AT_MATCHED_LATER_MOOD", "LATER_MOOD_EDGE_AT_MATCHED_INITIAL_MOOD"]},
        "pairs": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": {"$ref": "#/$defs/token"}, "uniqueItems": true
          },
          "uniqueItems": true
        },
        "meaning": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "candidatePattern": {
      "type": "object", "additionalProperties": false,
      "required": ["pattern_id", "initial_edge_relation", "later_edge_relation"],
      "properties": {
        "pattern_id": {"$ref": "#/$defs/token"},
        "initial_edge_relation": {"enum": ["MUST_REMAIN_EQUAL", "MUST_DIFFER_IF_PLACEMENT", "MAY_DIFFER_DOWNSTREAM"]},
        "later_edge_relation": {"enum": ["MUST_REMAIN_EQUAL", "MUST_DIFFER_IF_PLACEMENT", "MAY_DIFFER_DOWNSTREAM"]},
        "aggregate_rule": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "relFactorial": {
      "type": "object", "additionalProperties": false,
      "required": ["factorial_id", "family_id", "source_probe_id", "horizon_id", "fixed_initial_factor_levels", "later_option_mapping", "cells", "edge_classes", "candidate_patterns", "authority", "no_new_external_target_evidence", "no_scalar_recovery_or_ignition_score"],
      "properties": {
        "factorial_id": {"$ref": "#/$defs/token"},
        "family_id": {"const": "REL-BOUNDARY-001"},
        "source_probe_id": {"const": "rel.probe.same_cue_later_mood"},
        "horizon_id": {"const": "H_REGISTERED_FUTURE_ACCESS_K_PLUS_1"},
        "fixed_initial_factor_levels": {
          "type": "object", "additionalProperties": false,
          "required": ["target_history", "externally_cued_prior_material"],
          "properties": {
            "target_history": {"$ref": "#/$defs/token"},
            "externally_cued_prior_material": {"$ref": "#/$defs/token"}
          }
        },
        "later_option_mapping": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {"$ref": "#/$defs/laterOptionMapping"}, "uniqueItems": true
        },
        "cells": {
          "type": "array", "minItems": 4, "maxItems": 4,
          "items": {"$ref": "#/$defs/factorialCell"}, "uniqueItems": true
        },
        "edge_classes": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {"$ref": "#/$defs/factorialEdgeClass"}, "uniqueItems": true
        },
        "candidate_patterns": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/candidatePattern"}, "uniqueItems": true
        },
        "authority": {"const": "CONDITIONAL_PATTERN_DEFINITIONS_NOT_EXPECTED_HUMAN_RESULTS"},
        "no_new_external_target_evidence": {"const": true},
        "no_scalar_recovery_or_ignition_score": {"const": true}
      }
    },
    "d2aChallenge": {
      "type": "object", "additionalProperties": false,
      "required": ["challenge_id", "function", "status", "varied_input", "clamped_fields", "observed_field", "conditional_relation"],
      "properties": {
        "challenge_id": {"$ref": "#/$defs/token"},
        "function": {"enum": ["GHOST", "ADJUDICATOR", "ACTION_GATE"]},
        "status": {"const": "NO_001A_NATURAL_INTERVENTION"},
        "varied_input": {"$ref": "#/$defs/nonEmptyString"},
        "clamped_fields": {"$ref": "#/$defs/tokenList"},
        "observed_field": {"$ref": "#/$defs/token"},
        "conditional_relation": {"const": "MUST_DIFFER_IF_PLACEMENT"}
      }
    },
    "aliasRule": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "required_scope_keys", "definition", "observed_equality_status", "observed_equality_is_not_alias", "durable_cache_rule", "no_factor_retirement"],
      "properties": {
        "status": {"const": "PREREGISTERED_NO_ALIAS_RESULT"},
        "required_scope_keys": {"$ref": "#/$defs/uniqueStringList"},
        "definition": {"$ref": "#/$defs/nonEmptyString"},
        "observed_equality_status": {"const": "EMPIRICALLY_UNRESOLVED_UNDER_SCOPE"},
        "observed_equality_is_not_alias": {"const": true},
        "durable_cache_rule": {"$ref": "#/$defs/nonEmptyString"},
        "no_factor_retirement": {"const": true}
      }
    },
    "outOfModelPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "record_fields", "result_status", "forced_cast_to_registered_trace_field", "same_run_schema_expansion_and_rescoring", "next_protocol_version_required_for_new_domain", "scope_failure_status", "scope_failure_requirements", "normative_invariant_violation_is_out_of_model"],
      "properties": {
        "status": {"const": "RAW_PRESERVATION_PREREGISTERED_NO_RESULT"},
        "record_fields": {"$ref": "#/$defs/uniqueStringList"},
        "result_status": {"const": "OUT_OF_MODEL"},
        "forced_cast_to_registered_trace_field": {"const": "FORBIDDEN"},
        "same_run_schema_expansion_and_rescoring": {"const": "FORBIDDEN"},
        "next_protocol_version_required_for_new_domain": {"const": true},
        "scope_failure_status": {"const": "CURRENT_FUNCTIONAL_DECOMPOSITION_SCOPE_FAILURE"},
        "scope_failure_requirements": {"$ref": "#/$defs/uniqueStringList"},
        "normative_invariant_violation_is_out_of_model": {"const": false}
      }
    }
  }
}

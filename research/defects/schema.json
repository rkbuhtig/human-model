{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rkbuhtig/human-model/research/defects/schema.json",
  "title": "Human Model Defect Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "source",
    "artifact_status",
    "branch_status",
    "contemporaneous_record",
    "retrospective_interpretation",
    "principle_value"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^HM-DEFECT-[A-Z0-9-]+$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_commit", "artifacts"],
      "properties": {
        "baseline_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "line_ranges"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "line_ranges": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[0-9]+(-[0-9]+)?$"
                }
              }
            }
          }
        }
      }
    },
    "artifact_status": {
      "enum": [
        "OBSERVED_FAILURE",
        "LATENT_DESIGN_RISK",
        "AUTHOR_CLAIM"
      ]
    },
    "branch_status": {
      "enum": [
        "ADOPTED",
        "SIDE_BRANCH",
        "LATER_NOT_SELECTED",
        "UNKNOWN"
      ]
    },
    "contemporaneous_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_behavior",
        "contemporaneous_diagnosis",
        "historical_repair",
        "observed_side_effect"
      ],
      "properties": {
        "observed_behavior": {
          "type": "string",
          "minLength": 1
        },
        "contemporaneous_diagnosis": {
          "type": "string",
          "minLength": 1
        },
        "historical_repair": {
          "type": "string",
          "minLength": 1
        },
        "observed_side_effect": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "retrospective_interpretation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defect_classes",
        "candidate_principles",
        "competing_repairs",
        "legal_control_cases",
        "minimal_counterexample",
        "current_regression_tests",
        "empirical_status"
      ],
      "properties": {
        "defect_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "ILLEGAL_CAST",
              "UNAUTHORIZED_WRITE",
              "PROVENANCE_LOSS",
              "SCOPE_COLLAPSE",
              "TEMPORAL_ALIASING",
              "IDENTITY_COLLISION",
              "ORACLE_LEAKAGE"
            ]
          }
        },
        "candidate_principles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "principle_id",
              "statement",
              "predicted_repairs",
              "prohibited_legal_behavior",
              "failure_condition"
            ],
            "properties": {
              "principle_id": {
                "type": "string",
                "minLength": 1
              },
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "predicted_repairs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "prohibited_legal_behavior": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "failure_condition": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "competing_repairs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "legal_control_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "minimal_counterexample": {
          "type": "string",
          "minLength": 1
        },
        "current_regression_tests": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "empirical_status": {
          "enum": [
            "NOT_TESTED_ON_HUMANS",
            "PILOT_ONLY",
            "EMPIRICALLY_CONTESTED",
            "EMPIRICALLY_SUPPORTED"
          ]
        }
      }
    },
    "principle_value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "independent_defects_addressed",
        "discriminating_predictions",
        "blocked_legal_controls",
        "added_degrees_of_freedom"
      ],
      "properties": {
        "independent_defects_addressed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "discriminating_predictions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocked_legal_controls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "added_degrees_of_freedom": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
